From: Artur Stachecki <artur.stachecki@asml.com>
Date: Fri, 7 Feb 2025 08:02:58 +0000
Subject: [PATCH] feat: mark settings.bzl as public

---
 with_cfg.bzl                 | 3 ++-
 with_cfg/defs.bzl            | 2 ++
 with_cfg/private/setting.bzl | 2 +-
 3 files changed, 5 insertions(+), 2 deletions(-)

diff --git a/with_cfg.bzl b/with_cfg.bzl
index 4d330cc..6274799 100644
--- a/with_cfg.bzl
+++ b/with_cfg.bzl
@@ -1,4 +1,5 @@
-load("//with_cfg:defs.bzl", _original_settings = "original_settings", _with_cfg = "with_cfg")
+load("//with_cfg:defs.bzl", _original_settings = "original_settings", _with_cfg = "with_cfg", _validate_and_get_attr_name = "validate_and_get_attr_name")
 
 with_cfg = _with_cfg
 original_settings = _original_settings
+validate_and_get_attr_name = _validate_and_get_attr_name
diff --git a/with_cfg/defs.bzl b/with_cfg/defs.bzl
index 3e96f86..6e52828 100644
--- a/with_cfg/defs.bzl
+++ b/with_cfg/defs.bzl
@@ -1,3 +1,4 @@
+load("//with_cfg/private:setting.bzl", _validate_and_get_attr_name = "validate_and_get_attr_name")
 load("//with_cfg/private:original_settings.bzl", _original_settings = "original_settings")
 load("//with_cfg/private:with_cfg.bzl", _with_cfg = "with_cfg")
 
@@ -5,3 +6,4 @@ visibility("//")
 
 with_cfg = _with_cfg
 original_settings = _original_settings
+validate_and_get_attr_name = _validate_and_get_attr_name
diff --git a/with_cfg/private/setting.bzl b/with_cfg/private/setting.bzl
index 688a7a0..865424b 100644
--- a/with_cfg/private/setting.bzl
+++ b/with_cfg/private/setting.bzl
@@ -1,7 +1,7 @@
 load(":select.bzl", "map_attr")
 load(":utils.bzl", "is_bool", "is_int", "is_label", "is_list", "is_string")
 
-visibility(["//with_cfg/private/...", "//with_cfg/tests/..."])
+visibility(["//with_cfg/...", "//with_cfg/..."])
 
 def make_valid_identifier(name):
     """Makes a valid identifier name from a given string
