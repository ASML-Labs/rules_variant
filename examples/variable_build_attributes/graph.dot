      "//variable_build_attributes:rhel8x64/main_configurable_with_cfg (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel8x64/main_configurable_with_cfg</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:rhel10x64/main~v2 (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel10x64/main~v2</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:rhel10x64/main~v2_with_cfg (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel10x64/main~v2_with_cfg</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:rhel10x64/main_variable (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel10x64/main_variable</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:rhel10x64/main_variable_with_cfg (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel10x64/main_variable_with_cfg</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:rhel10x64/main_configurable (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel10x64/main_configurable</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:rhel10x64/main_configurable_with_cfg (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel10x64/main_configurable_with_cfg</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:main_variable (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:main_variable</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:main_configurable (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:main_configurable</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
      "//variable_build_attributes:main (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:main</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    

