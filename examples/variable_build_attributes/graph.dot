digraph CG {
  graph [splines=ortho, nodesep=0.6, ranksep=1, pad=0.5, rankdir=TB, clusterrank=local, overlap=false];
  overlap=false;
  node [shape=box];
  subgraph cluster_targets {
    label="Targets";
      "//variable_build_attributes:rhel8x64/main~v1 (diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">//variable_build_attributes:rhel8x64/main~v1</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid"]    
