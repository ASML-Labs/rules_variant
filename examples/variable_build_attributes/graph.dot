      "(diligent_technician)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">eec668 (diligent_technician)</TD></TR></TABLE>>,fillcolor="#eec668",color=black,style="filled,solid",shape=ellipse]
    configs [style=invis];
  }
  configs -> targets [style=invis];
  "//variable_build_attributes:rhel10x64/main_variable_with_cfg (diligent_technician)" -> "//variable_build_attributes:rhel10x64/main_variable_/main_variable (incompatible_height)" [color="#eec668"]
  "//variable_build_attributes:rhel8x64/main~v1 (diligent_technician)" -> "//variable_build_attributes:rhel8x64/main~v1_with_cfg (diligent_technician)" [color="#eec668"]
  "//variable_build_attributes:rhel10x64/main~v2 (diligent_technician)" -> "//variable_build_attributes:rhel10x64/main~v2_with_cfg (diligent_technician)" [color="#eec668"]
  "//variable_build_attributes:rhel10x64/main_configurable (diligent_technician)" -> "//variable_build_attributes:rhel10x64/main_configurable_with_cfg (diligent_technician)" [color="#eec668"]
  "//variable_build_attributes:rhel8x64/main_variable (diligent_technician)" -> "//variable_build_attributes:rhel8x64/main_variable_with_cfg (diligent_technician)" [color="#eec668"]
  "//variable_build_attributes:rhel8x64/main_configurable_with_cfg (diligent_technician)" -> "//variable_build_attributes:rhel8x64/main_configurable_/main_configurable (alert_pinstripe)" [color="#eec668"]
  "//variable_build_attributes:rhel10x64/main_variable (diligent_technician)" -> "//variable_build_attributes:rhel10x64/main_variable_with_cfg (diligent_technician)" [color="#eec668"]
  "//variable_build_attributes:rhel8x64/main_variable_with_cfg (diligent_technician)" -> "//variable_build_attributes:rhel8x64/main_variable_/main_variable (alert_pinstripe)" [color="#eec668"]
  "//variable_build_attributes:rhel8x64/main_configurable (diligent_technician)" -> "//variable_build_attributes:rhel8x64/main_configurable_with_cfg (diligent_technician)" [color="#eec668"]
  "//variable_build_attributes:rhel10x64/main_configurable_with_cfg (diligent_technician)" -> "//variable_build_attributes:rhel10x64/main_configurable_/main_configurable (incompatible_height)" [color="#eec668"]
