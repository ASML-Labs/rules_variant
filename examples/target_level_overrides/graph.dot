      "(common_lime)" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0"><TR><TD BGCOLOR="white">acbc2c (common_lime)</TD></TR></TABLE>>,fillcolor="#acbc2c",color=black,style="filled,solid",shape=ellipse]
